[Domain]
Name=Waydroid Management
Icon=color

[org.kde.plasma.mobileshell.waydroidhelper.initialize]
Name=Initialize Waydroid
Description=Allow initialization of Waydroid
Policy=yes
PolicyInactive=yes
Persistence=session